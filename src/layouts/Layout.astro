---
  import ColorToggle from '@/components/ColorToggle.svelte';
  import MobileNav from '@/components/MobileNav.svelte';
  import Email from '@/components/icons/Email.astro';
  import GitHub from '@/components/icons/GitHub.astro';
  import Linkedin from '@/components/icons/Linkedin.astro';
  import { HANDLE_GITHUB, HANDLE_LINKEDIN, EMAIL } from '@/constants';
  import '@/styles/base.css';
  import { classNames } from '@/utils/styling';
  export interface Props {
    title?: string;
    description?: string;
  }

  const { title, description } = Astro.props as Props;

  const currentPath = new URL(Astro.request.url).pathname;

  const linkStyle = 'text-gray-500 dark:text-gray-400 hover:text-primary-dark-text dark:hover:text-primary-light transition-colors duration-200';
  const activeStyle = 'text-primary-dark-text dark:text-primary-light';
---

<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  <meta name="generator" content={Astro.generator} />
  <title>{title ? `${title} - Brian Chan` : 'Brian Chan'}</title>

  <!-- SEO Stuff -->
  <link rel="canonical" href={Astro.request.url} />
  <meta name="description" content={description ?? 'Brian Chan - Researcher in pharmacology and data science.' } />
  <meta name="robots" content="follow, index" />

  <!-- OG Card -->
  <meta property="og:site_name" content="brianphchan.com" />
  <meta property="og:title" content={title ? `${title} - Brian Chan` : 'Brian Chan'} />
  <meta property="og:description" content={description
    ?? "Brian Chan - Researcher in pharmacology and data science." } />
  <meta property="og:url" content="https://brianphchan.com" />
  <meta property="og:image" content="https://brianphchan.com/images/share.png" />
  <meta property="og:type" content="website" />

  <!-- Analytics -->
  <script defer data-domain="brianphchan.com" data-api="/plausible/api/event" src="/plausible/js/script.js"></script>

  <script is:inline>
    const theme = (() => {
      if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
        return localStorage.getItem('theme');
      }
      if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
        return 'dark';
      }
      return 'light';
    })();

    if (theme === 'light') {
      document.documentElement.classList.remove('dark');
    } else {
      document.documentElement.classList.add('dark');
    }
    window.localStorage.setItem('theme', theme);
  </script>
</head>

<body class="bg-white dark:bg-primary-dark text-primary-dark-text dark:text-primary-light antialiased">
  <main class="space-y-12 md:space-y-16 pt-8 pb-2">
    <nav class="max-w-2xl mx-auto px-4 sm:px-6 md:px-0">
      <div class="hidden md:flex items-center justify-center gap-8 text-sm">
        <a class={classNames(currentPath === '/' ? activeStyle : linkStyle)}
          href="/">Home</a>
        <a class={classNames(currentPath.startsWith('/caseStudies') ? activeStyle : linkStyle)}
          href="/caseStudies">Projects</a>
        <a class={classNames(currentPath.startsWith('/workExperience') ? activeStyle : linkStyle)}
          href="/workExperience">Work</a>
        <a class={classNames(currentPath.startsWith('/aboutMe') ? activeStyle : linkStyle)}
          href="/aboutMe">About</a>
        <ColorToggle client:load />
      </div>
      <div class="flex items-center justify-end gap-2 md:hidden">
        <ColorToggle client:load />
        <MobileNav client:load />
      </div>
    </nav>
    <div class="max-w-2xl mx-auto px-4 sm:px-6 md:px-0">
      <slot />
    </div>
  </main>

  <footer class="max-w-2xl mx-auto px-4 sm:px-6 md:px-0 pb-8 pt-16">
    <div class="border-t border-gray-100 dark:border-neutral-800 pt-8">
      <div class="flex flex-col sm:flex-row justify-between items-center gap-4">
        <div class="flex items-center gap-5">
          <a
            class="text-gray-300 dark:text-gray-600 hover:text-gray-500 dark:hover:text-gray-400 transition-colors duration-200"
            href={`https://www.linkedin.com/in/${HANDLE_LINKEDIN}`}
            target="_blank"
            aria-label="LinkedIn"
          >
            <Linkedin />
          </a>
          <a
            class="text-gray-300 dark:text-gray-600 hover:text-gray-500 dark:hover:text-gray-400 transition-colors duration-200"
            href={`https://github.com/${HANDLE_GITHUB}`}
            target="_blank"
            aria-label="GitHub"
          >
            <GitHub />
          </a>
          <a
            class="text-gray-300 dark:text-gray-600 hover:text-gray-500 dark:hover:text-gray-400 transition-colors duration-200"
            href={`mailto:${EMAIL}`}
            aria-label="Email"
          >
            <Email />
          </a>
        </div>
        <p class="text-gray-300 dark:text-gray-600 text-xs">
          &copy; {new Date().getFullYear()} Brian Chan
        </p>
      </div>
    </div>
  </footer>
</body>

</html>
