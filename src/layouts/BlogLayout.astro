---
  import Layout from '@/layouts/Layout.astro';
  import { getHumanizedDate } from '@/utils/date';

  const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title} description={frontmatter.summary}>
  <div class="space-y-8">
    <a href="/caseStudies" class="text-sm text-gray-400 dark:text-gray-500 hover:text-primary-dark-text dark:hover:text-primary-light transition-colors duration-200">
      &larr; Projects
    </a>
    <div class="space-y-2">
      <h1 class="text-3xl md:text-4xl font-semibold tracking-tight">{frontmatter.title}</h1>
      <p class="text-sm text-gray-400 dark:text-gray-500">{getHumanizedDate(frontmatter.pubDate)}</p>
    </div>
    <article class="prose lg:prose-lg dark:prose-invert prose-gray">
      <slot />
    </article>
  </div>
</Layout>
