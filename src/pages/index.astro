---
import BlogPostPreview from "@/components/BlogPostPreview.astro";
import Email from "@/components/icons/Email.astro";
import GitHub from "@/components/icons/GitHub.astro";
import Linkedin from "@/components/icons/Linkedin.astro";
import { EMAIL, HANDLE_GITHUB, HANDLE_LINKEDIN } from "@/constants";
import Layout from "@/layouts/Layout.astro";

const allPosts = Object.values(
  import.meta.glob("./caseStudies/**/*.mdx", { eager: true })
);

const sortedPosts = allPosts
  .filter((post) => post.frontmatter && post.frontmatter.pubDate)
  .sort(
    (a, b) =>
      new Date(b.frontmatter.pubDate).valueOf() -
      new Date(a.frontmatter.pubDate).valueOf()
  );
---

<Layout>
  <div class="space-y-20">
    <!-- Hero -->
    <div class="space-y-5">
      <h1 class="text-4xl font-semibold tracking-tight md:text-5xl">
        Brian Chan
      </h1>
      <p class="text-lg text-gray-500 dark:text-gray-400 leading-relaxed">
        Pharmacology researcher and data scientist at Merck, building tools at the intersection of biology and computation.
      </p>
      <div class="flex items-center gap-4 pt-1">
        <a
          class="text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition-colors duration-200"
          href={`https://www.linkedin.com/in/${HANDLE_LINKEDIN}`}
          target="_blank"
          aria-label="LinkedIn"
        >
          <Linkedin />
        </a>
        <a
          class="text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition-colors duration-200"
          href={`https://github.com/${HANDLE_GITHUB}`}
          target="_blank"
          aria-label="GitHub"
        >
          <GitHub />
        </a>
        <a
          class="text-gray-400 hover:text-gray-600 dark:text-gray-500 dark:hover:text-gray-300 transition-colors duration-200"
          href={`mailto:${EMAIL}`}
          aria-label="Email"
        >
          <Email />
        </a>
      </div>
    </div>

    <!-- Projects -->
    <div class="space-y-6">
      <h2 class="text-sm font-medium uppercase tracking-widest text-gray-400 dark:text-gray-500">Projects</h2>
      <div class="space-y-1">
        {sortedPosts.map((post) => <BlogPostPreview post={post} />)}
      </div>
      <a href="/caseStudies" class="inline-block text-sm text-gray-500 dark:text-gray-400 hover:text-primary-dark-text dark:hover:text-primary-light transition-colors duration-200">
        View all &rarr;
      </a>
    </div>

    <!-- About Teaser -->
    <div class="space-y-4">
      <h2 class="text-sm font-medium uppercase tracking-widest text-gray-400 dark:text-gray-500">About</h2>
      <p class="text-gray-500 dark:text-gray-400 leading-relaxed">
        Researcher based in Cambridge, Massachusetts, with a background in regenerative therapy and pharmacology. Currently at Merck developing high-throughput assays for drug discovery.
      </p>
      <a
        href="/aboutMe"
        class="inline-block text-sm text-gray-500 dark:text-gray-400 hover:text-primary-dark-text dark:hover:text-primary-light transition-colors duration-200"
      >
        Read more &rarr;
      </a>
    </div>
  </div>
</Layout>
