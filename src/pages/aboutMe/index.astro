---
import Layout from "../../layouts/Layout.astro";
const imagePath = "/images/Personal/me.jpeg";
---

<Layout title="About Me">
  <div class="space-y-16">
    <h1 class="text-4xl font-semibold tracking-tight">About</h1>

    <!-- Bio Section -->
    <div class="flex flex-col md:flex-row items-start gap-10">
      <div class="w-full md:w-2/5 flex-shrink-0">
        <img src={imagePath} alt="Brian Chan" class="w-full rounded-lg" />
      </div>
      <div class="w-full md:w-3/5 space-y-4 text-gray-500 dark:text-gray-400 leading-relaxed">
        <p>
          Thanks for checking out my website! My name is Brian, and I am a researcher
          based in Cambridge, Massachusetts. Using my academic background in
          regenerative therapy and pharmacology, I hope to contribute to the
          development of cool, life-changing therapeutics.
        </p>
        <p>
          As a growing scientist, I've had the opportunity to work with many
          notable PIs and teams. Currently, I am working at Merck to develop
          high-throughput assays for drug discovery.
        </p>
        <p>
          Outside of the lab, I'm passionate about data science and machine learning,
          and I enjoy applying computational methods to biological problems.
        </p>
        <p>
          Feel free to connect on any of the socials I have linked. :)
        </p>
      </div>
    </div>

    <!-- Education & Certifications -->
    <div class="space-y-8">
      <h2 class="text-sm font-medium uppercase tracking-widest text-gray-400 dark:text-gray-500">Education & Certifications</h2>
      <div class="space-y-6">
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4">
          <span class="text-sm text-gray-400 dark:text-gray-500 sm:w-28 flex-shrink-0">2024</span>
          <div>
            <h4 class="font-medium">MIT Professional Education</h4>
            <a href="https://professional.mit.edu/course-catalog/applied-data-science-program-leveraging-ai-effective-decision-making" class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary-dark-text dark:hover:text-primary-light transition-colors duration-200" target="_blank">Applied Data Science</a>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4">
          <span class="text-sm text-gray-400 dark:text-gray-500 sm:w-28 flex-shrink-0">2022</span>
          <div>
            <h4 class="font-medium">Google Certificate</h4>
            <a href="https://www.coursera.org/professional-certificates/google-data-analytics" class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary-dark-text dark:hover:text-primary-light transition-colors duration-200" target="_blank">Data Analytics</a>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4">
          <span class="text-sm text-gray-400 dark:text-gray-500 sm:w-28 flex-shrink-0">2021 &ndash; 2022</span>
          <div>
            <h4 class="font-medium">Imperial College London</h4>
            <a href="https://www.imperial.ac.uk/study/pg/medicine/genes-drugs-stem-cells/" class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary-dark-text dark:hover:text-primary-light transition-colors duration-200" target="_blank">MSc in Genes, Drugs, and Stem Cells</a>
          </div>
        </div>
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4">
          <span class="text-sm text-gray-400 dark:text-gray-500 sm:w-28 flex-shrink-0">2017 &ndash; 2021</span>
          <div>
            <h4 class="font-medium">The University of Toronto</h4>
            <a href="https://artsci.calendar.utoronto.ca/section/Pharmacology-and-Toxicology" class="text-sm text-gray-500 dark:text-gray-400 hover:text-primary-dark-text dark:hover:text-primary-light transition-colors duration-200" target="_blank">hBSc in Pharmacology and Toxicology</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
