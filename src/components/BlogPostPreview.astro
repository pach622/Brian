---
  export interface Props {
    post: any;
  }

  import { parseISO, format } from 'date-fns';
  import { getSlugFromPath } from '@/utils/getSlugFromPath';

  const { post } = Astro.props;
  const url = '/caseStudies/' + getSlugFromPath(post.file);
  const date = parseISO(post.frontmatter.pubDate);
  const formattedDate = format(date, 'LLLL d, yyyy');
---

<a href={url} class="group block py-4 border-b border-gray-100 dark:border-neutral-800 last:border-0">
  <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1">
    <h4 class="font-medium group-hover:text-gray-500 dark:group-hover:text-gray-400 transition-colors duration-200">{post.frontmatter.title}</h4>
    <span class="text-sm text-gray-400 dark:text-gray-500 flex-shrink-0">{formattedDate}</span>
  </div>
  <p class="text-sm text-gray-500 dark:text-gray-400 mt-1 leading-relaxed">{post.frontmatter.summary}</p>
</a>
